# ============================================
# ICEYE API Credentials (REQUIRED)
# ============================================
# Get these from your ICEYE account manager
ICEYE_CLIENT_ID=your-client-id-here
ICEYE_CLIENT_SECRET=your-client-secret-here

# ============================================
# ICEYE API Endpoints (REQUIRED)
# ============================================
# API base URL
ICEYE_API_URL=https://platform.iceye.com/api

# OAuth base URL (provided by ICEYE)
# Note: Do NOT include /v1/token - the backend appends this automatically
ICEYE_AUTH_URL=your-oauth-base-url-here

# ============================================
# Application Configuration
# ============================================
# Frontend URL for CORS (Cross-Origin Resource Sharing)
# For local development: http://localhost:5173
# For production: Set to your deployed frontend URL (e.g., https://yourdomain.com)
FRONTEND_URL=http://localhost:5173

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your ICEYE credentials:
#    - ICEYE_CLIENT_ID
#    - ICEYE_CLIENT_SECRET
#    - ICEYE_AUTH_URL (OAuth token URL provided by ICEYE)
# 3. Save and start the backend: uvicorn api.main:app --reload
#
# SECURITY: Never commit .env to git!
